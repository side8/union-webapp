---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Union">
  <div class="py-12 text-center">
    <h1 class="font-wordmark text-7xl italic text-union-charcoal">Union</h1>
    <p
      class="mx-auto mt-8 max-w-2xl font-prayer text-2xl leading-relaxed text-union-secondary"
    >
      When you don&apos;t have the words, two thousand years of Christians
      have left some for you. Union helps you find them.
    </p>
  </div>

  <section class="mt-16 grid gap-6">
    <p class="text-lg leading-relaxed text-union-charcoal">
      Union is a private prayer companion. Tell it what&apos;s on your heart;
      it answers with words from the church&apos;s long tradition — the
      Anglican Book of Common Prayer, Reformed devotions, Methodist
      collects, ancient and modern voices.
    </p>
    <p class="text-lg leading-relaxed text-union-charcoal">
      What you share stays yours. We don&apos;t sell it, share it, or use it
      to train AI models.
    </p>
  </section>

  <section class="mt-16 rounded-2xl border border-union-border bg-white p-6">
    <h2 class="text-sm uppercase tracking-[0.2em] text-union-secondary">
      Coming soon
    </h2>
    <p class="mt-3 text-lg leading-relaxed text-union-charcoal">
      Union is in private beta on iOS. If you&apos;d like to test it,
      email <a class="text-union-gold underline" href="mailto:hello@unionwith.app"
      >hello@unionwith.app</a>.
    </p>
  </section>
</Layout>
