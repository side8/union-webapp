---
import '../styles/global.css'

// Shared document shell for the marketing site. Provides <head> (fonts
// + meta) and the `.wrap` container; pages slot in their header,
// content, and footer. EB Garamond (display + body) and IBM Plex Sans
// (UI labels) loaded from Google Fonts via <link rel="preconnect"> for
// fast first paint.

interface Props {
  title: string
  description?: string
}

const { title, description } = Astro.props
const fullTitle = title === 'Union' ? 'Union' : `${title} · Union`
const meta =
  description ??
  'Union is a private prayer companion. Bring what is on your heart and Union meets you with the prayers Christians have prayed for centuries.'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={meta} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=IBM+Plex+Sans:wght@400;500;600&display=swap"
    />
    <slot name="head" />
  </head>
  <body>
    <div class="wrap">
      <slot />
    </div>
  </body>
</html>
